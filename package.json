{
  "name": "wgpu-ol-renderer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "GPU-first geospatial rendering pipeline for OpenLayers (foundation layer)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/geojson-worker-client.d.ts",
      "import": "./dist/client/geojson-worker-client.js"
    },
    "./ingest-client": {
      "types": "./dist/client/ingest-worker-client.d.ts",
      "import": "./dist/client/ingest-worker-client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:bench": "npm run build && vite build --config vite.bench.config.ts",
    "verify:pan-zoom": "npm run build:bench && playwright test tests/pan-zoom-bench.spec.ts",
    "bench:pan-zoom": "npm run build:bench && vite preview --config vite.bench.config.ts --port 4174 --host 127.0.0.1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@webgpu/types": "^0.1.69",
    "typescript": "~5.7.0",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "@geoarrow/geoarrow-js": "^0.3.3",
    "apache-arrow": "^21.1.0",
    "buffer": "^6.0.3",
    "flatgeobuf": "^4.4.0",
    "wkx": "^0.5.0"
  }
}
